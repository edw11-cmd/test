# OpenAI Configuration (using placeholder - replace with real key)
OPENAI_API_KEY=sk-placeholder-key-replace-with-real-openai-key
OPENAI_MODEL=gpt-4-turbo-preview

# Opik Configuration (optional - replace with real key if available)
OPIK_API_KEY=opik-placeholder-key
OPIK_WORKSPACE=hypercortex-ai
OPIK_PROJECT_NAME=hypercortex-main

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Database Configuration
DATABASE_URL=sqlite:///./hypercortex.db

# Security
SECRET_KEY=hypercortex-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Configuration
APP_NAME=HyperCortex-AI
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=12000

# Memory Configuration
VECTOR_STORE_TYPE=faiss
MAX_MEMORY_SIZE=10000
MEMORY_SIMILARITY_THRESHOLD=0.7

# Agent Configuration
MAX_ITERATIONS=10
REFLECTION_ENABLED=True
TOOL_TIMEOUT=30

# Monitoring
ENABLE_METRICS=True
LOG_LEVEL=INFO