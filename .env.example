# Opik Configuration (required - provides OpenAI access)
OPIK_API_KEY=XvVArO*****************
OPIK_WORKSPACE=tak11-cloud
OPIK_PROJECT_NAME=hypercortex-main

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Database Configuration
DATABASE_URL=sqlite:///./hypercortex.db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Configuration
APP_NAME=HyperCortex-AI
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=12000

# Memory Configuration
VECTOR_STORE_TYPE=faiss  # Options: faiss, chroma, redis
MAX_MEMORY_SIZE=10000
MEMORY_SIMILARITY_THRESHOLD=0.7

# Agent Configuration
MAX_ITERATIONS=10
REFLECTION_ENABLED=True
TOOL_TIMEOUT=30

# Monitoring
ENABLE_METRICS=True
LOG_LEVEL=INFO